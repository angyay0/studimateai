{
  "name": "studymate-backend",
  "version": "1.0.0",
  "description": "StudyMate AI - Backend API",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"tsc --watch\" \"node --watch dist/index.js\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "openai:test": "node scripts/test-openai-connection.js",
    "db:migrate": "node scripts/run-migrations.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.1",
    "pg": "^8.11.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "express-validator": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.8.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/jest": "^29.5.8",
    "@types/multer": "^1.4.11",
    "@types/pg": "^8.11.10",
    "typescript": "^5.2.2",
    "eslint": "^8.51.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "prettier": "^3.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "concurrently": "^8.2.1",
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
