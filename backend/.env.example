# ============================================================================
# Backend Environment Variables - StudyMate AI
# ============================================================================
# Copy this file to .env and fill in the values for your environment

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
BACKEND_PORT=5000
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
# Option 1: Use full connection string (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studymate_ai

# Option 2: Use individual parameters (if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studymate_ai
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================================================
# AUTHENTICATION (JWT)
# ============================================================================
# CRITICAL: Change this in production! Use a random 32+ character string
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# ============================================================================
# OPENAI CONFIGURATION (AI/RAG)
# ============================================================================
# REQUIRED: Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
EMBEDDING_MODEL=text-embedding-3-small

# RAG Configuration
OPENAI_RAG_MODEL=gpt-4-turbo
OPENAI_VECTOR_STORE_PREFIX=exam-rag

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_FILE_SIZE=20971520
ALLOWED_FILE_TYPES=pdf,txt,md,docx
UPLOAD_DIR=uploads

# Storage Provider (optional: local, s3, spaces)
STORAGE_PROVIDER=local
STORAGE_BUCKET=

# ============================================================================
# DIGITALOCEAN SPACES / S3 CONFIGURATION (Optional)
# ============================================================================
# Only required if STORAGE_PROVIDER=spaces or STORAGE_PROVIDER=s3
# Get credentials from: https://cloud.digitalocean.com/account/api/tokens
SPACES_ACCESS_KEY=your-spaces-access-key
SPACES_SECRET_KEY=your-spaces-secret-key
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=your-bucket-name-u

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
