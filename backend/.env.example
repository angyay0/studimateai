# ============================================================================
# Backend Environment Variables - StudyMate AI
# ============================================================================
# Copy this file to .env and fill in the values for your environment

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
NODE_ENV=development
BACKEND_PORT=5000
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studymate_ai
DB_USER=postgres
DB_PASSWORD=postgres
# Full DATABASE_URL (alternative to individual config)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studymate_ai

# ============================================================================
# AUTHENTICATION (JWT)
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=7d

# ============================================================================
# OPENAI CONFIGURATION (IA/RAG)
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
MAX_FILE_SIZE=20971520
ALLOWED_FILE_TYPES=pdf
UPLOAD_DIR=uploads

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# RAG CONFIGURATION
# ============================================================================
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_TOP_K_RESULTS=5
RAG_MIN_RELEVANCE_SCORE=0.7
