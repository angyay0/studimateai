{
  "name": "StudyMate AI",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  // Instala dependencias y compila el backend al abrir el contenedor
  "postCreateCommand": "npm install && npm run build:backend",

  // Reenvío de puertos: backend (5000) y frontend (3000)
  "forwardPorts": [5000, 3000],
  "portsAttributes": {
    "5000": { "label": "Backend API", "onAutoForward": "notify" },
    "3000": { "label": "Frontend", "onAutoForward": "openBrowser" }
  },

  // Variables de entorno que SIEMPRE necesitas — los secretos los pones
  // en GitHub → Settings → Codespaces → Secrets (no aquí para no exponerlos)
  "remoteEnv": {
    "NODE_ENV": "development"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "github.copilot",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
